    "@heroicons/react": "^2.0.18",
    "@mapbox/mapbox-gl-draw": "^1.4.2",
    "@tanstack/react-query": "^5.32.0",
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.0",
    "dompurify": "^3.0.6",
    "isomorphic-dompurify": "^2.11.0",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.21",
    "mapbox-gl": "^2.15.0",
    "next": "^14.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.1",
    "recharts": "^2.10.3",
    "zod": "^3.22.4"

# NestSafely Frontend Environment Variables

# =============================================================================
# API Configuration
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3000/v1
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3001

# =============================================================================
# Map & Location Services
# =============================================================================
# Get token from: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk_your_mapbox_token_here

# =============================================================================
# Analytics (Optional)
# =============================================================================
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# =============================================================================
# Feature Flags
# =============================================================================
NEXT_PUBLIC_ENABLE_STRIPE=false
NEXT_PUBLIC_ENABLE_DEMO_MODE=false

# =============================================================================
# App Configuration
# =============================================================================
NEXT_PUBLIC_APP_NAME=NestSafely
NEXT_PUBLIC_APP_DESCRIPTION=Property Safety Intelligence Platform

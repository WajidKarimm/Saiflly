# NestSafely Backend Environment Variables

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=nestsafely
DB_SSL=false
DB_POOL_SIZE=20
DB_POOL_IDLE_TIMEOUT=30000

# =============================================================================
# REDIS CACHE
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# JWT & AUTHENTICATION
# =============================================================================
# Must be at least 32 characters long
JWT_SECRET=your_super_secret_key_minimum_32_characters_long
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=2592000

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
LOG_LEVEL=debug

# =============================================================================
# SECURITY & CORS
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,https://nestsafely.com
CORS_CREDENTIALS=true

# =============================================================================
# EXTERNAL API KEYS (AI & DATA)
# =============================================================================

# Claude API (Anthropic)
CLAUDE_API_KEY=sk-your-claude-api-key-here

# Google Places API
GOOGLE_PLACES_API_KEY=AIza_your_google_places_api_key_here

# (Optional) Other data providers
# NADRA_API_KEY=
# NDMA_API_KEY=
# CRIME_DATABASE_API_KEY=

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_DIR=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# Sentry (Error tracking - optional)
SENTRY_DSN=

# =============================================================================
# DATA INGESTION & CACHING
# =============================================================================
SCORE_CACHE_TTL=86400
SEARCH_CACHE_TTL=3600
FACILITY_CACHE_TTL=604800

# =============================================================================
# DEPLOYMENT ENVIRONMENT (Set these in production)
# =============================================================================
# ENVIRONMENT_NAME=production
# DEPLOYMENT_REGION=us-east-1
# DEPLOYMENT_VERSION=1.0.0
